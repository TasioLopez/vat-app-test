# Copy to .env.local for local development.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (document extraction, TP autofill)
OPENAI_API_KEY=

# Gotenberg — DOCX/DOC → PDF before vision extraction (optional for PDF-only uploads)
# Local: docker run --rm -p 3000:3000 gotenberg/gotenberg:8
GOTENBERG_URL=http://localhost:3000

# Optional: if Gotenberg is protected with a shared secret header
# GOTENBERG_API_KEY=
